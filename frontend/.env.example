NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgres://postgres:postgres@localhost:5432/florisight

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FLORISIGHT_PYTHON_BIN=python3
FLORISIGHT_YOLO_MODEL=yolov8n.pt
FLORISIGHT_TRACK_CONFIDENCE=0.35
FLORISIGHT_TRACK_FRAME_STRIDE=1
FLORISIGHT_PATH_POINT_STRIDE=5
FLORISIGHT_MIN_DWELL_SECONDS=3

# Optional free local LLM via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
